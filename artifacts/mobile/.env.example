# --- Flux mobile (Expo) environment ---
# All EXPO_PUBLIC_* vars are inlined into the app bundle at build time.

# API server base URL (no /api suffix).
# Production (Render): https://flux-api.onrender.com
# Local dev on device: http://<your-mac-lan-ip>:8080
EXPO_PUBLIC_API_URL=https://flux-api.onrender.com

# Build mode: testing | production
# testing = orange banner, full Premium access for QA, safe Paystack test keys on API
EXPO_PUBLIC_FLUX_ENV=testing

# --- Firebase web config (flux-screenshotos) ---
# Leave these unset to run without a login gate (dev mode; pair with an
# API server that also has no FIREBASE_PROJECT_ID set).
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=flux-screenshotos.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=flux-screenshotos
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=flux-screenshotos.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Paystack (live public key — same account as ScoutGrid)
EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=

# Google Sign-In (Firebase Console → Authentication → Sign-in method → Google → Web client ID)
# Also create iOS/Android OAuth clients in Google Cloud Console for standalone builds.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
