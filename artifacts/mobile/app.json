{
  "expo": {
    "name": "Flux",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0C0C14",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.flux.screenshotos",
      "icon": "./assets/images/icon.png",
      "googleServicesFile": "./firebase/GoogleService-Info.plist",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Flux uses Face ID to keep your screenshots private when app lock is enabled."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0C0C14"
      },
      "package": "com.flux.screenshotos",
      "googleServicesFile": "./firebase/google-services.json",
      "intentFilters": [
        {
          "action": "android.intent.action.SEND",
          "category": ["android.intent.category.DEFAULT"],
          "data": [{ "mimeType": "image/*" }]
        }
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0C0C14"
        }
      ],
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-media-library",
        {
          "photosPermission": "Flux reads your Screenshots album to classify and organize them automatically.",
          "savePhotosPermission": "Allow Flux to access photos.",
          "isAccessMediaLocationEnabled": false,
          "granularPermissions": [
            "photo"
          ]
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.629513991075-3cveb0kbok06hn5g2eccleo4b34pche3"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#7C72FF"
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Flux adds events detected in your screenshots to your calendar."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Flux uses Face ID to keep your screenshots private when app lock is enabled."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
