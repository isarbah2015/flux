{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "testing": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_FLUX_ENV": "testing",
        "EXPO_PUBLIC_API_URL": "https://flux-api-2els.onrender.com"
      },
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_FLUX_ENV": "production"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
