# --- Flux API server environment ---

# Postgres connection (local dev default shown)
DATABASE_URL=postgresql://apple@localhost:5432/flux

# Port the server listens on
PORT=8080

# API environment: testing | production | development
# testing = allows Paystack test keys even when NODE_ENV=production (hosted QA)
FLUX_ENV=testing

# Firebase Auth: set to your Flux project id to ENFORCE per-user auth.
# Leave unset for local dev (requests are attributed to a single "local-dev" user).
# FIREBASE_PROJECT_ID=flux-screenshotos

# Anthropic key enables Claude vision OCR + classification.
# Leave unset to use the deterministic keyword fallback.
# ANTHROPIC_API_KEY=sk-ant-...

# Paystack — Flux Premium billing ($9.99 USD one-time, lifetime access)
# Sync live keys: bash scripts/sync-paystack-from-scoutgrid.sh
# PAYSTACK_SECRET_KEY=sk_live_...
# PAYSTACK_PUBLIC_KEY=pk_live_...
# PAYSTACK_REQUIRE_LIVE=true

# Optional: comma-separated emails that always receive lifetime Premium
# PREMIUM_GRANT_EMAILS=isarbah2015@gmail.com
